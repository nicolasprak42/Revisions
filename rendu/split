#include <unistd.h>
#include <stdio.h>

char **ft_split(char *str, char *charset)
{
	char **tab
	int i;
	int j;
	int k;
	
	i = 0;
	j = 0;
	k = 0;
	tab = malloc(sizeof(*char) * 1000);
	while(str[i] >= 9 && str[i] <= 13 || str[i] ==' ')
		i++;
	while(str[i])
	{
		if(str[i] >32)
		{
			tab[j] = malloc(sizeof(char) * 1000);
			while (str[i] && str[i] > 32)
				tab[j][k++] = str[i++];
			tab[j][k] = '\0';
			k = 0; 
			j++;
		}
		else
			i++
	}
	tab[j] = NULL;
	return (tab);
}